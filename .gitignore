# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Virtual environment
.venv/
venv/

# Environment
.env
.env.local

# Training artifacts (regenerated per-run, keep examples)
models/adapters/*
# Keep the bundled SRE assistant adapter (small LoRA) so the appliance ships a
# ready fine-tuned model; merged at first boot.
!models/adapters/sre-assistant
models/gguf/

# Per-run datasets / history / DBs (generated locally, not source).
# Ignore everything under data/ EXCEPT the demo datasets, which ship with the
# repo so a fresh clone can reproduce the SRE demo (the models themselves are
# too large for git and are rebuilt by scripts/run_sre_demo.sh).
data/*
!data/sre-pods/
data/sre-pods/*
!data/sre-pods/dataset_v1.jsonl
!data/sre-pods/dataset_v2.jsonl
!data/example_train.jsonl
# Bundled, generated datasets (deterministic SEED=42) committed for visibility — the
# image regenerates identical copies at build. Training Q&A:
!data/sre-tables-train/
data/sre-tables-train/*
!data/sre-tables-train/sre_qa.jsonl
!data/sre-tables-train/sre_qa_v1.jsonl
!data/sre-tables-train/sre_qa_v2.jsonl
# 43 SRE observability tables (the cards / text-to-SQL data):
!data/sre-tables/
data/sre-tables/*
!data/sre-tables/*.csv

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ML caches (huge, download once)
.huggingface/
.cache/huggingface/

# Logs
*.log
/tmp/
logs/

# Mise
.mise.toml

# Demo video output
*.mp4
*.webm
