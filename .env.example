# ── Optional API Keys ─────────────────────────────────────
# The platform auto-detects what's available and falls back gracefully.
# If none of these are set, the platform uses commandcode API (cmd -p).
#
# Copy this file to .env and fill in the keys you have.

# TinyFish + OpenRouter (for BigSet dataset generation)
# Get keys at: https://agent.tinyfish.ai/api-keys
#             https://openrouter.ai/settings/keys
# BIGSET_TINYFISH_KEY=tf_...
# OPENROUTER_KEY=sk-or-...

# HuggingFace token (for higher API rate limits during model discovery)
# HF_TOKEN=hf_...

# Port configuration (optional, defaults shown)
# PORT=7100
# INFERENCE_PORT=7200
